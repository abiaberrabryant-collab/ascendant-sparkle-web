{
  "version": 1,
  "sdk_version": "0.23.0",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://pdobdzurqgmrpvykleoa.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "ascendantweb-mcp",
      "version": "0.1.0",
      "title": "AscendantWeb"
    },
    "tools": [
      {
        "name": "list_conversations",
        "title": "List chatbot conversations",
        "description": "List AscendantWeb chatbot conversations visible to the signed-in user (admins see all).",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "default": 50,
              "description": "Max rows to return.",
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_conversation",
        "title": "Get chatbot conversation",
        "description": "Return the messages of a single AscendantWeb chatbot conversation by id.",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "conversation_id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "description": "Conversation id."
            }
          },
          "required": [
            "conversation_id"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_leads",
        "title": "List captured leads",
        "description": "List leads captured by the AscendantWeb chatbot (admin only under RLS).",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "default": 50,
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_chatbot_settings",
        "title": "Get chatbot settings",
        "description": "Return the full AscendantWeb chatbot settings row (admin only), including knowledge base.",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "update_chatbot_settings",
        "title": "Update chatbot settings",
        "description": "Update AscendantWeb chatbot settings (admin only). Only provided fields are changed.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "greeting": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500
            },
            "business_knowledge": {
              "description": "Knowledge base text.",
              "type": "string",
              "maxLength": 50000
            },
            "system_prompt": {
              "type": "string",
              "minLength": 1,
              "maxLength": 8000
            },
            "brand_color": {
              "type": "string",
              "pattern": "^#[0-9a-fA-F]{6}$"
            },
            "suggested_prompts": {
              "maxItems": 6,
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 120
              }
            },
            "model": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_orders",
        "title": "List orders",
        "description": "List AscendantWeb Stripe orders (admin only).",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "default": 50,
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_subscriptions",
        "title": "List subscriptions",
        "description": "List AscendantWeb subscriptions (admin only).",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "default": 50,
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            }
          }
        },
        "outputSchema": null
      }
    ]
  }
}
